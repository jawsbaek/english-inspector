# LLM API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-key

# Model Configuration (PDF spec 2026 models)
GENERATION_MODEL=openai/gpt-5.2
EVALUATION_MODEL=anthropic/claude-sonnet-4-6
MULTIMODAL_MODEL=google/gemini-3.1-pro

# DSPy Settings
BEST_OF_N=3
MAX_RETRIES=2

# Database
DATABASE_URL=sqlite+aiosqlite:///./english_inspector.db
